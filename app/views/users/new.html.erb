<section class="auth-shell">
  <div class="app-card auth-card">
    <div class="mb-4 text-center">
      <p class="hero-kicker">New Account</p>
      <h1 class="h2 mb-2">Sign up</h1>
      <p class="text-secondary mb-0">Create an account to access the admin workspace.</p>
    </div>

    <%= form_with(model: @user, local: true, class: "vstack gap-3") do |f| %>
      <%= render "shared/error_messages" %>

      <div>
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control form-control-lg" %>
      </div>

      <div>
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, class: "form-control form-control-lg" %>
      </div>

      <div>
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, class: "form-control form-control-lg" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmation", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control form-control-lg" %>
      </div>

      <%= f.submit "Create my account", class: "btn btn-primary btn-lg w-100 mt-2" %>
    <% end %>

    <p class="text-center text-secondary mt-4 mb-0">
      Already registered?
      <%= link_to "Login", login_path, class: "text-decoration-none" %>
    </p>
  </div>
</section>
