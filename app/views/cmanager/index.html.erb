<section class="hero-card">
  <div class="row g-4 align-items-center">
    <div class="col-lg-7">
      <p class="hero-kicker">Campaign Manager Admin</p>
      <h1 class="display-6 fw-semibold mb-3">Manage banners and campaigns from one small dashboard.</h1>
      <p class="lead text-secondary mb-4">
        Create banners, attach them to campaigns, and expose the public banner endpoint without dragging in a heavy admin UI.
      </p>
      <div class="d-flex flex-wrap gap-2">
        <% if sess_loggedin? %>
          <% user = sess_current_user %>
          <%= link_to "View Campaigns", user_campaigns_path(user), class: "btn btn-primary px-4" %>
          <%= link_to "View Banners", user_banners_path(user), class: "btn btn-outline-secondary px-4" %>
        <% else %>
          <%= link_to "Create Account", newuser_path, class: "btn btn-primary px-4" %>
          <%= link_to "Login", login_path, class: "btn btn-outline-secondary px-4" %>
        <% end %>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="app-card compact-card h-100">
        <h2 class="h5 mb-3">How it works</h2>
        <ul class="info-list mb-0">
          <li>Private admin pages manage users, banners, and campaigns.</li>
          <li>React admin screens consume a versioned JSON API inside the Rails app.</li>
          <li><code>/publicbanner</code> serves a currently eligible banner.</li>
        </ul>
      </div>
    </div>
  </div>
</section>
