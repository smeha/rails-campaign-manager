<section class="auth-shell">
  <div class="app-card auth-card">
    <div class="mb-4 text-center">
      <p class="hero-kicker">Welcome Back</p>
      <h1 class="h2 mb-2">Login</h1>
      <p class="text-secondary mb-0">Use your account to manage banners and campaigns.</p>
    </div>

    <%= form_with(url: login_path, scope: :session, local: true, class: "vstack gap-3") do |f| %>
      <div>
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, class: "form-control form-control-lg", autofocus: true %>
      </div>

      <div>
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, class: "form-control form-control-lg" %>
      </div>

      <%= f.submit "Log in", class: "btn btn-primary btn-lg w-100 mt-2" %>
    <% end %>

    <p class="text-center text-secondary mt-4 mb-0">
      Need an account?
      <%= link_to "Create one", newuser_path, class: "text-decoration-none" %>
    </p>
  </div>
</section>
